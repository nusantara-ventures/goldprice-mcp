{
  "name": "@goldprice/mcp",
  "version": "0.1.3",
  "description": "Stdio bridge for the goldprice.dev Model Context Protocol server. Drops Claude Desktop, Cursor, or any MCP client into live gold prices in 30 seconds.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nusantara-ventures/goldprice-mcp.git"
  },
  "type": "module",
  "bin": {
    "mcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test tests/*.test.mjs",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "gold",
    "xau",
    "precious-metals",
    "api",
    "claude",
    "cursor",
    "goldprice"
  ],
  "homepage": "https://goldprice.dev/docs/mcp",
  "license": "MIT",
  "author": "Nusantara Ventures LLC <hello@goldprice.dev>"
}
